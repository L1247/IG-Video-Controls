{
  "manifest_version": 3,
  "name": "IG Story Checker",
  "version": "1.0",
  "description": "檢查 Instagram 頁面是否有限時動態",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.instagram.com/*"
  ],
  "action": {
    "default_title": "IG Story Checker",
    "default_icon": "icon128.png",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://www.instagram.com/stories/*"],
      "js": ["stories_autoplay.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icon128.png"
  }
}
